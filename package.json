{
	"name": "@api-wrappers/anilist-wrapper",
	"version": "2.5.1",
	"description": "A comprehensive and easy-to-use TypeScript wrapper for the Anilist GraphQL API (v2). Simplifies fetching anime/manga data and managing user lists in Node.js applications.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"homepage": "https://github.com/Api-Wrappers/anilist-wrapper#readme",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Api-Wrappers/anilist-wrapper.git"
	},
	"keywords": [
		"anilist",
		"api",
		"wrapper",
		"client",
		"sdk",
		"graphql",
		"anime",
		"manga",
		"anilist api",
		"anilist client",
		"anilist sdk",
		"node",
		"nodejs",
		"typescript",
		"library"
	],
	"author": {
		"name": "api-wrappers",
		"url": "https://github.com/api-wrappers"
	},
	"license": "MIT",
	"private": false,
	"exports": {
		"import": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"require": {
			"types": "./dist/index.d.cts",
			"default": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "bun run build",
		"codegen": "rimraf src/__generated__ && graphql-codegen --config codegen.yml && bun run codegen:patch",
		"codegen:patch": "bun scripts/patch-codegen.ts",
		"test": "bun test --timeout 10000",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@graphql-codegen/cli": "^7.0.0",
		"@graphql-codegen/typescript": "^6.0.1",
		"@graphql-codegen/typescript-graphql-request": "^7.0.1",
		"@graphql-codegen/typescript-operations": "^6.0.2",
		"@types/bun": "^1.3.13",
		"graphql": "^16.14.0",
		"rimraf": "^6.1.3",
		"tsdown": "^0.22.0"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@api-wrappers/api-core": "^0.0.2"
	}
}
